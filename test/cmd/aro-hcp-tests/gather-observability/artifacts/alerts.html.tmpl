<html>
<head>
  <title>Azure Monitor Alerts</title>
  <meta name="description" content="Azure Monitor alerts fired during e2e test run.">
  <link rel="stylesheet" type="text/css" href="/static/style.css">
  <link rel="stylesheet" type="text/css" href="/static/extensions/style.css">
  <link href="https://fonts.googleapis.com/css?family=Roboto:400,700" rel="stylesheet">
  <link rel="stylesheet" href="https://code.getmdl.io/1.3.0/material.indigo-pink.min.css">
  <link rel="stylesheet" type="text/css" href="/static/spyglass/spyglass.css">
  <style>
    body {
      background-color: #0d1117;
      color: #e6edf3;
      font-family: 'Roboto', -apple-system, sans-serif;
      margin: 0;
      padding: 16px 24px;
    }

    /* --- Summary cards --- */
    .summary-bar {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin: 16px 0 24px 0;
    }
    .summary-card {
      background: #161b22;
      border: 1px solid #30363d;
      border-radius: 8px;
      padding: 16px 28px;
      text-align: center;
      min-width: 120px;
      flex: 1;
    }
    .summary-card-number {
      font-size: 32px;
      font-weight: 700;
      line-height: 1.2;
    }
    .summary-card-label {
      font-size: 11px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #8b949e;
      margin-top: 4px;
    }
    .color-total             { color: #e6edf3; }
    .color-unknown           { color: #da3633; }
    .color-known             { color: #d29922; }
    .color-severity-critical { color: #da3633; }
    .color-severity-error    { color: #d29922; }
    .color-severity-warning  { color: #d29922; }
    .color-severity-info     { color: #316dca; }
    .color-severity-verbose  { color: #8b949e; }

    .badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 3px;
      font-weight: 700;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }
    .severity-critical { background-color: #da3633; color: #fff; }
    .severity-error    { background-color: #d29922; color: #000; }
    .severity-warning  { background-color: #d29922; color: #000; }
    .severity-info     { background-color: #316dca; color: #fff; }
    .severity-verbose  { background-color: #484f58; color: #e6edf3; }

    .meta {
      color: #8b949e;
      font-size: 13px;
      margin-bottom: 4px;
    }
    .meta span { margin-right: 20px; }

    .no-alerts {
      color: #3fb950;
      font-size: 18px;
      padding: 24px;
      text-align: center;
    }

    /* --- Alert cards --- */
    .alert-card {
      background-color: #161b22;
      border: 1px solid #30363d;
      border-radius: 6px;
      padding: 16px 20px;
      border-left: 4px solid #da3633;
    }
    .alert-card-known {
      border-left-color: #9e6a03;
      opacity: 0.8;
    }

    /* Top row: badges + condition + cluster + time */
    .alert-header {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }
    .alert-header .badge { padding: 2px 8px; font-size: 12px; }

    .condition-fired    { color: #f85149; font-weight: 700; }
    .condition-resolved { color: #3fb950; font-weight: 700; }

    .alert-time {
      color: #8b949e;
      font-size: 13px;
      margin-left: auto;
    }

    /* Alert title */
    .alert-title {
      font-size: 15px;
      font-weight: 700;
      margin-bottom: 6px;
      color: #e6edf3;
    }

    /* Description */
    .alert-description {
      font-size: 14px;
      line-height: 1.6;
      color: #c9d1d9;
      margin-bottom: 8px;
    }

    /* Labels grid */
    .alert-labels {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-top: 8px;
    }
    .alert-labels .label-chip {
      display: inline-block;
      background: #21262d;
      border: 1px solid #30363d;
      padding: 2px 8px;
      border-radius: 3px;
      font-size: 12px;
      color: #8b949e;
      font-family: monospace;
    }
    .alert-labels .label-chip .label-key {
      color: #58a6ff;
    }

    /* Collapsible known-issue alerts */
    details.known-details {
      list-style: none;
    }
    details.known-details > summary {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      cursor: pointer;
      user-select: none;
      list-style: none;
    }
    details.known-details > summary::-webkit-details-marker { display: none; }
    details.known-details > summary::before {
      content: "\25B6";
      font-size: 10px;
      color: #8b949e;
      transition: transform 0.15s;
    }
    details[open].known-details > summary::before {
      transform: rotate(90deg);
    }
    details.known-details > summary .badge { padding: 2px 8px; font-size: 12px; }
    .alert-title-inline {
      font-size: 15px;
      font-weight: 700;
      color: #e6edf3;
    }
    .known-reason-inline {
      font-size: 13px;
      color: #d29922;
      margin-left: auto;
    }
    .known-reason-inline strong {
      text-transform: uppercase;
      letter-spacing: 0.3px;
      font-size: 11px;
      background: rgba(158, 106, 3, 0.15);
      padding: 2px 6px;
      border-radius: 3px;
      border: 1px solid #9e6a03;
    }
    .alert-details-body {
      margin-top: 12px;
    }

    /* --- Duration bar --- */
    .duration-bar {
      height: 3px;
      background: #21262d;
      overflow: hidden;
    }
    .duration-bar-fill {
      height: 100%;
    }
    .alert-row {
      margin: 10px 0;
      padding-bottom: 4px;
    }
    .duration-bar-fill-unknown { background: #da3633; }
    .duration-bar-fill-known   { background: #9e6a03; }

    /* --- Time slider --- */
    .time-slider-group {
      padding: 12px 0 16px 0;
      border-bottom: 1px solid #30363d;
      margin-bottom: 16px;
    }
    .time-slider-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
    }
    .time-slider-label {
      font-size: 12px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #8b949e;
    }
    .time-slider-values {
      font-size: 13px;
      color: #e6edf3;
      font-family: monospace;
    }
    .time-slider-track {
      position: relative;
      height: 24px;
      background: #21262d;
      border-radius: 4px;
      cursor: pointer;
    }
    .time-slider-range {
      position: absolute;
      height: 100%;
      background: #58a6ff;
      opacity: 0.3;
      border-radius: 4px;
    }
    .time-slider-handle {
      position: absolute;
      top: 50%;
      transform: translate(-50%, -50%);
      width: 16px;
      height: 16px;
      background: #58a6ff;
      border: 2px solid #0d1117;
      border-radius: 50%;
      cursor: grab;
      z-index: 2;
    }
    .time-slider-handle:hover { background: #79c0ff; }
    .time-slider-handle:active { cursor: grabbing; }
    .time-slider-ticks {
      display: flex;
      justify-content: space-between;
      margin-top: 4px;
      font-size: 10px;
      color: #8b949e;
      font-family: monospace;
    }
    .time-slider-reset {
      background: none;
      border: 1px solid #30363d;
      color: #8b949e;
      padding: 2px 10px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 12px;
      margin-left: 12px;
    }
    .time-slider-reset:hover { color: #e6edf3; border-color: #8b949e; }

    /* Collapsible PromQL */
    details.query-details {
      margin-top: 8px;
    }
    details.query-details summary {
      cursor: pointer;
      font-size: 12px;
      color: #58a6ff;
      user-select: none;
      padding: 4px 0;
    }
    details.query-details summary:hover {
      text-decoration: underline;
    }
    .alert-expr {
      font-family: monospace;
      font-size: 12px;
      color: #8b949e;
      background: #0d1117;
      border: 1px solid #30363d;
      padding: 10px 12px;
      border-radius: 4px;
      margin-top: 6px;
      white-space: pre-wrap;
      word-break: break-all;
      line-height: 1.5;
    }

    /* Runbook link */
    .alert-links {
      margin-top: 8px;
    }
    .alert-links a {
      font-size: 12px;
      color: #58a6ff;
      text-decoration: none;
    }
    .alert-links a:hover {
      text-decoration: underline;
    }

    .badge-workspace {
      background: #21262d;
      border: 1px solid #30363d;
      color: #8b949e;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* --- Filter bar --- */
    .filter-bar {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
      padding: 12px 0;
      border-bottom: 1px solid #30363d;
      margin-bottom: 16px;
    }
    .filter-bar-label {
      font-size: 12px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #8b949e;
      margin-right: 4px;
    }
    .filter-dropdown {
      position: relative;
      display: inline-block;
    }
    .filter-dropdown-btn {
      background: #21262d;
      border: 1px solid #30363d;
      color: #e6edf3;
      padding: 5px 12px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 13px;
      font-family: inherit;
      white-space: nowrap;
    }
    .filter-dropdown-btn:hover { border-color: #8b949e; }
    .filter-dropdown-btn .filter-count {
      color: #8b949e;
      font-size: 11px;
      margin-left: 4px;
    }
    .filter-dropdown-menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      margin-top: 4px;
      background: #161b22;
      border: 1px solid #30363d;
      border-radius: 6px;
      padding: 6px 0;
      min-width: 200px;
      max-height: 280px;
      overflow-y: auto;
      z-index: 100;
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    }
    .filter-dropdown-menu.open { display: block; }
    .filter-checkbox-item {
      display: flex;
      align-items: center;
      padding: 4px 12px;
      cursor: pointer;
      font-size: 13px;
      color: #c9d1d9;
    }
    .filter-checkbox-item:hover { background: #21262d; }
    .filter-checkbox-item input {
      margin-right: 8px;
      accent-color: #58a6ff;
    }
    .filter-checkbox-item .filter-value {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      font-family: monospace;
      font-size: 12px;
    }
    .filter-reset-btn {
      background: none;
      border: 1px solid #30363d;
      color: #8b949e;
      padding: 5px 12px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 12px;
    }
    .filter-reset-btn:hover { color: #e6edf3; border-color: #8b949e; }
  </style>
</head>

<body>

  {{if .HasAlerts}}
  <div class="summary-bar">
    <div class="summary-card">
      <div class="summary-card-number color-total">{{.Summary.Total}}</div>
      <div class="summary-card-label">Total</div>
    </div>
    <div class="summary-card">
      <div class="summary-card-number color-unknown">{{.UnknownCount}}</div>
      <div class="summary-card-label">Alerts</div>
    </div>
    <div class="summary-card">
      <div class="summary-card-number color-known">{{.KnownCount}}</div>
      <div class="summary-card-label">Known Alerts</div>
    </div>
    {{range $sev, $count := .SeverityCounts}}
    <div class="summary-card">
      <div class="summary-card-number color-{{severityClass $sev}}">{{$count}}</div>
      <div class="summary-card-label">{{$sev}}</div>
    </div>
    {{end}}
  </div>

  {{if .FilterKeys}}
  <div class="filter-bar" id="filterBar">
    <span class="filter-bar-label">Filters</span>
    {{range $key := .FilterKeys}}{{$values := index $.FilterOptions $key}}
    <div class="filter-dropdown" data-filter-key="{{$key}}">
      <button class="filter-dropdown-btn" type="button">{{$key}} <span class="filter-count">(0/{{len $values}})</span></button>
      <div class="filter-dropdown-menu">
        {{range $values}}
        <label class="filter-checkbox-item"><input type="checkbox" value="{{.}}"><span class="filter-value">{{.}}</span></label>
        {{end}}
      </div>
    </div>
    {{end}}
    <button class="filter-reset-btn" id="resetFilters" type="button">Reset Filters</button>
  </div>
  {{end}}

  <div class="time-slider-group" id="timeSliderContainer">
    <div class="time-slider-header">
      <span class="time-slider-label">Time Range</span>
      <span>
        <span class="time-slider-values" id="timeSliderValues"></span>
        <button class="time-slider-reset" id="resetTimeSlider">Reset</button>
      </span>
    </div>
    <div class="time-slider-track" id="timeSliderTrack">
      <div class="time-slider-range" id="timeSliderRange"></div>
      <div class="time-slider-handle" id="timeSliderStart" data-handle="start"></div>
      <div class="time-slider-handle" id="timeSliderEnd" data-handle="end"></div>
    </div>
    <div class="time-slider-ticks">
      <span id="tickStart"></span>
      <span id="tickEnd"></span>
    </div>
  </div>

  {{range $i, $a := .Alerts}}
  <div class="alert-row" data-alert-idx="{{$i}}">
  {{if $a.Metadata.KnownIssue}}
  <div class="alert-card alert-card-known">
    <details class="known-details">
      <summary>
        <span class="badge badge-workspace">{{$a.Metadata.MonitoringWorkspaceType}}</span>
        <span class="badge {{severityClass $a.Alert.Severity}}">{{$a.Alert.Severity}}</span>
        <span class="{{conditionClass $a.Alert.Condition}}">{{$a.Alert.Condition}}</span>
        <span class="alert-title-inline">{{$a.Alert.Name}}</span>
        <span class="known-reason-inline">{{$a.Metadata.KnownIssueReason}} <strong>Known Issue</strong></span>
      </summary>
      <div class="alert-details-body">
        <div class="alert-header">
          <span class="alert-time">
            Fired: {{formatTime $a.Alert.StartsAt}} {{relativeTime $.TimeWindow.Start $a.Alert.StartsAt}}{{if $a.Alert.EndsAt}} &middot; Resolved: {{formatTime $a.Alert.EndsAt}} {{relativeTime $.TimeWindow.Start $a.Alert.EndsAt}}{{end}}
          </span>
        </div>
        {{if $a.Alert.Description}}<div class="alert-description">{{$a.Alert.Description}}</div>{{end}}

        {{if $a.Alert.Labels}}
        <div class="alert-labels">
          {{range $k, $v := $a.Alert.Labels}}<span class="label-chip"><span class="label-key">{{$k}}</span>=<span>{{$v}}</span></span>{{end}}
        </div>
        {{end}}

        {{with annotation $a.Alert.Annotations "runbook_url"}}{{if ne . "TBD"}}
        <div class="alert-links"><a href="{{.}}" target="_blank" rel="noopener">View Runbook &rarr;</a></div>
        {{end}}{{end}}

        {{if $a.Alert.Expression}}
        <details class="query-details">
          <summary>View PromQL Query</summary>
          <div class="alert-expr">{{$a.Alert.Expression}}</div>
        </details>
        {{end}}
      </div>
    </details>
  </div>
  {{else}}
  <div class="alert-card">
    <div class="alert-header">
      <span class="badge badge-workspace">{{$a.Metadata.MonitoringWorkspaceType}}</span>
      <span class="badge {{severityClass $a.Alert.Severity}}">{{$a.Alert.Severity}}</span>
      <span class="{{conditionClass $a.Alert.Condition}}">{{$a.Alert.Condition}}</span>
      <span class="alert-time">
        Fired: {{formatTime $a.Alert.StartsAt}} {{relativeTime $.TimeWindow.Start $a.Alert.StartsAt}}{{if $a.Alert.EndsAt}} &middot; Resolved: {{formatTime $a.Alert.EndsAt}} {{relativeTime $.TimeWindow.Start $a.Alert.EndsAt}}{{end}}
      </span>
    </div>
    <div class="alert-title">{{$a.Alert.Name}}</div>
    {{if $a.Alert.Description}}<div class="alert-description">{{$a.Alert.Description}}</div>{{end}}

    {{if $a.Alert.Labels}}
    <div class="alert-labels">
      {{range $k, $v := $a.Alert.Labels}}<span class="label-chip"><span class="label-key">{{$k}}</span>=<span>{{$v}}</span></span>{{end}}
    </div>
    {{end}}

    {{with annotation $a.Alert.Annotations "runbook_url"}}{{if ne . "TBD"}}
    <div class="alert-links"><a href="{{.}}" target="_blank" rel="noopener">View Runbook &rarr;</a></div>
    {{end}}{{end}}

    {{if $a.Alert.Expression}}
    <details class="query-details">
      <summary>View PromQL Query</summary>
      <div class="alert-expr">{{$a.Alert.Expression}}</div>
    </details>
    {{end}}
  </div>
  {{end}}
  <div class="duration-bar"><div class="duration-bar-fill {{if $a.Metadata.KnownIssue}}duration-bar-fill-known{{else}}duration-bar-fill-unknown{{end}}" id="bar-{{$i}}"></div></div>
  </div>
  {{end}}

  {{else}}
  <div class="no-alerts">No alerts fired during the test window.</div>
  {{end}}

  <!-- workaround for spyglass cutting off page bottoms -->
  <div style="height: 20px;"></div>

  <script>
  (function() {
    var windowStart = new Date("{{.TimeWindow.Start}}").getTime();
    var windowEnd = new Date("{{.TimeWindow.End}}").getTime();
    var totalDuration = windowEnd - windowStart;
    if (totalDuration <= 0) return;

    var alerts = [
      {{range $i, $a := .Alerts}}{ idx: {{$i}}, start: {{if $a.Alert.StartsAt}}new Date("{{formatTime $a.Alert.StartsAt}} UTC").getTime(){{else}}0{{end}}, end: {{if $a.Alert.EndsAt}}new Date("{{formatTime $a.Alert.EndsAt}} UTC").getTime(){{else}}windowEnd{{end}}, known: {{if $a.Metadata.KnownIssue}}true{{else}}false{{end}}, severity: "{{$a.Alert.Severity}}", labels: {{alertFilterJSON $a}} },
      {{end}}
    ];

    var alertLabels = alerts.map(function(a) { return a.labels; });

    // Store original summary values
    var origTotal = {{.Summary.Total}};
    var origUnknown = {{.Summary.Unknown}};
    var origKnown = {{.Summary.Known}};

    function fmt(ms) {
      var d = new Date(ms);
      return d.getUTCHours().toString().padStart(2,'0') + ':' + d.getUTCMinutes().toString().padStart(2,'0') + ':' + d.getUTCSeconds().toString().padStart(2,'0');
    }

    // Duration bars
    var track = document.getElementById('timeSliderTrack');
    alerts.forEach(function(a) {
      var bar = document.getElementById('bar-' + a.idx);
      if (!bar || !a.start) return;
      var left = ((a.start - windowStart) / totalDuration) * 100;
      var width = Math.max(((a.end - a.start) / totalDuration) * 100, 0.5);
      bar.style.marginLeft = left + '%';
      bar.style.width = width + '%';
    });

    // Time slider state
    var filterStart = windowStart;
    var filterEnd = windowEnd;
    var startHandle = document.getElementById('timeSliderStart');
    var endHandle = document.getElementById('timeSliderEnd');
    var range = document.getElementById('timeSliderRange');
    var dragging = null;

    document.getElementById('tickStart').textContent = fmt(windowStart);
    document.getElementById('tickEnd').textContent = fmt(windowEnd);

    function updateSlider() {
      var sp = ((filterStart - windowStart) / totalDuration) * 100;
      var ep = ((filterEnd - windowStart) / totalDuration) * 100;
      startHandle.style.left = sp + '%';
      endHandle.style.left = ep + '%';
      range.style.left = sp + '%';
      range.style.width = (ep - sp) + '%';
      document.getElementById('timeSliderValues').textContent = fmt(filterStart) + ' \u2014 ' + fmt(filterEnd);
    }

    // --- Label filter state ---
    // Filters default to unselected except classification, which
    // pre-selects "unknown" to surface unclassified alerts on load.
    // Checking a value restricts to only matching alerts.
    // Cascading: each dropdown's options recompute from alerts passing
    // all OTHER active filters, so you never see options that do nothing.
    function getCheckedValues() {
      var checked = {};
      document.querySelectorAll('.filter-dropdown').forEach(function(dd) {
        var key = dd.getAttribute('data-filter-key');
        var vals = [];
        dd.querySelectorAll('input[type="checkbox"]').forEach(function(cb) {
          if (cb.checked) vals.push(cb.value);
        });
        if (vals.length > 0) checked[key] = vals;
      });
      return checked;
    }

    function passesFilters(idx, filters) {
      var labels = alertLabels[idx];
      for (var key in filters) {
        var allowed = filters[key];
        var val = labels[key];
        if (val === undefined || val === '') return false;
        if (allowed.indexOf(val) === -1) return false;
      }
      return true;
    }

    function passesTimeFilter(a) {
      return a.start <= filterEnd && a.end >= filterStart;
    }

    // Rebuild a dropdown's checkboxes from available values.
    // Preserves checked state for values that still exist.
    function rebuildDropdown(dd, availableValues) {
      var menu = dd.querySelector('.filter-dropdown-menu');
      var currentChecked = {};
      menu.querySelectorAll('input[type="checkbox"]').forEach(function(cb) {
        if (cb.checked) currentChecked[cb.value] = true;
      });
      var sorted = availableValues.slice().sort();
      menu.innerHTML = '';
      sorted.forEach(function(val) {
        var label = document.createElement('label');
        label.className = 'filter-checkbox-item';
        var cb = document.createElement('input');
        cb.type = 'checkbox';
        cb.value = val;
        if (currentChecked[val]) cb.checked = true;
        cb.addEventListener('change', filterCards);
        var span = document.createElement('span');
        span.className = 'filter-value';
        span.textContent = val;
        label.appendChild(cb);
        label.appendChild(span);
        menu.appendChild(label);
      });
    }

    function updateDropdownOptions() {
      var checked = getCheckedValues();
      var dropdowns = document.querySelectorAll('.filter-dropdown');

      dropdowns.forEach(function(dd) {
        var thisKey = dd.getAttribute('data-filter-key');
        // Build filters excluding this dropdown's key
        var otherFilters = {};
        for (var k in checked) {
          if (k !== thisKey) otherFilters[k] = checked[k];
        }
        // Collect values for thisKey from alerts passing all other filters + time
        var available = {};
        alerts.forEach(function(a, i) {
          if (!passesTimeFilter(a)) return;
          if (!passesFilters(i, otherFilters)) return;
          var val = alertLabels[i][thisKey];
          if (val !== undefined && val !== '') available[val] = true;
        });
        rebuildDropdown(dd, Object.keys(available));
        // Update button count
        var cbs = dd.querySelectorAll('input[type="checkbox"]');
        var total = cbs.length;
        var checkedCount = 0;
        cbs.forEach(function(cb) { if (cb.checked) checkedCount++; });
        var countSpan = dd.querySelector('.filter-count');
        if (countSpan) countSpan.textContent = '(' + checkedCount + '/' + total + ')';
      });
    }

    // --- Unified filter: time + labels ---
    function filterCards() {
      var checked = getCheckedValues();
      var visTotal = 0, visKnown = 0, visUnknown = 0;

      alerts.forEach(function(a, i) {
        var card = document.querySelector('[data-alert-idx="' + a.idx + '"]');
        if (!card) return;
        var visible = passesTimeFilter(a) && passesFilters(i, checked);
        card.style.display = visible ? '' : 'none';
        if (visible) {
          visTotal++;
          if (a.known) visKnown++;
          else visUnknown++;
        }
      });

      updateSummaryCards(visTotal, visUnknown, visKnown);
      updateDropdownOptions();
    }

    function updateSummaryCards(visTotal, visUnknown, visKnown) {
      var cards = document.querySelectorAll('.summary-card');
      if (cards.length < 3) return;
      var isFiltered = visTotal !== origTotal;
      cards[0].querySelector('.summary-card-number').textContent = isFiltered ? visTotal + ' / ' + origTotal : origTotal;
      cards[1].querySelector('.summary-card-number').textContent = isFiltered ? visUnknown + ' / ' + origUnknown : origUnknown;
      cards[2].querySelector('.summary-card-number').textContent = isFiltered ? visKnown + ' / ' + origKnown : origKnown;
    }

    // --- Dropdown toggle ---
    document.querySelectorAll('.filter-dropdown-btn').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var menu = btn.nextElementSibling;
        var wasOpen = menu.classList.contains('open');
        document.querySelectorAll('.filter-dropdown-menu').forEach(function(m) { m.classList.remove('open'); });
        if (!wasOpen) menu.classList.toggle('open');
      });
    });
    document.addEventListener('click', function() {
      document.querySelectorAll('.filter-dropdown-menu').forEach(function(m) { m.classList.remove('open'); });
    });

    // --- Reset filters ---
    var resetBtn = document.getElementById('resetFilters');
    if (resetBtn) {
      resetBtn.addEventListener('click', function() {
        document.querySelectorAll('.filter-dropdown input[type="checkbox"]').forEach(function(cb) { cb.checked = false; });
        filterCards();
      });
    }

    // --- Time slider drag ---
    function onDrag(e) {
      if (!dragging) return;
      var rect = track.getBoundingClientRect();
      var pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
      var t = windowStart + pct * totalDuration;
      if (dragging === 'start') filterStart = Math.min(t, filterEnd - 1000);
      else filterEnd = Math.max(t, filterStart + 1000);
      updateSlider();
    }
    function stopDrag() {
      if (dragging) { dragging = null; filterCards(); }
      document.removeEventListener('mousemove', onDrag);
      document.removeEventListener('mouseup', stopDrag);
    }
    startHandle.addEventListener('mousedown', function(e) {
      e.preventDefault(); dragging = 'start';
      document.addEventListener('mousemove', onDrag);
      document.addEventListener('mouseup', stopDrag);
    });
    endHandle.addEventListener('mousedown', function(e) {
      e.preventDefault(); dragging = 'end';
      document.addEventListener('mousemove', onDrag);
      document.addEventListener('mouseup', stopDrag);
    });
    track.addEventListener('click', function(e) {
      if (e.target === startHandle || e.target === endHandle) return;
      var rect = track.getBoundingClientRect();
      var pct = (e.clientX - rect.left) / rect.width;
      var t = windowStart + pct * totalDuration;
      if (Math.abs(t - filterStart) < Math.abs(t - filterEnd)) filterStart = Math.min(t, filterEnd - 1000);
      else filterEnd = Math.max(t, filterStart + 1000);
      updateSlider(); filterCards();
    });
    document.getElementById('resetTimeSlider').addEventListener('click', function() {
      filterStart = windowStart; filterEnd = windowEnd;
      updateSlider(); filterCards();
    });

    updateSlider();

    // Attach stopPropagation once per menu so clicks inside don't close the dropdown
    document.querySelectorAll('.filter-dropdown-menu').forEach(function(menu) {
      menu.addEventListener('click', function(e) { e.stopPropagation(); });
    });

    // Pre-check "unknown" in classification filter on page load
    var classDD = document.querySelector('.filter-dropdown[data-filter-key="classification"]');
    if (classDD) {
      classDD.querySelectorAll('input[type="checkbox"]').forEach(function(cb) {
        if (cb.value === 'unknown') cb.checked = true;
      });
    }
    filterCards();
  })();
  </script>
</body>
</html>
