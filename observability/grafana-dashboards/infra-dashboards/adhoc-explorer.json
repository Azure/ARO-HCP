{
  "title": "Ad-hoc Explorer",
  "description": "Explorer-like dashboard for ad-hoc PromQL queries in read-only Grafana instances",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"],
    "time_options": ["5m", "15m", "30m", "1h", "3h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": "^Managed_Prometheus_.*$",
        "skipUrlSync": false
      },
      {
        "name": "metric",
        "type": "query",
        "label": "Metrics",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(__name__)",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 2,
        "sort": 1,
        "skipUrlSync": false
      },
      {
        "name": "query",
        "type": "textbox",
        "label": "PromQL",
        "current": {
          "value": "up"
        },
        "hide": 0,
        "skipUrlSync": false
      },
      {
        "name": "step",
        "type": "textbox",
        "label": "Min Step",
        "current": {
          "value": ""
        },
        "hide": 0,
        "skipUrlSync": false
      }
    ]
  },
  "panels": [
    {
      "title": "Time Series",
      "type": "timeseries",
      "id": 1,
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "axisPlacement": "auto",
            "spanNulls": false
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": ["lastNotNull", "mean", "max", "min"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "$query",
          "legendFormat": "__auto",
          "interval": "$step",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Summary",
      "type": "stat",
      "id": 2,
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 14 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "count($query)",
          "legendFormat": "Series Count",
          "refId": "A",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "avg($query)",
          "legendFormat": "Avg",
          "refId": "B",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum($query)",
          "legendFormat": "Sum",
          "refId": "C",
          "instant": true
        }
      ]
    },
    {
      "title": "Top 10",
      "type": "bargauge",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-blues" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "minVizWidth": 8,
        "minVizHeight": 16,
        "valueMode": "color",
        "namePlacement": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "topk(10, $query)",
          "legendFormat": "{{__name__}} {{pod}} {{container}} {{namespace}} {{instance}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "Bottom 10",
      "type": "bargauge",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-reds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "minVizWidth": 8,
        "minVizHeight": 16,
        "valueMode": "color",
        "namePlacement": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "bottomk(10, $query)",
          "legendFormat": "{{__name__}} {{pod}} {{container}} {{namespace}} {{instance}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "Table",
      "type": "table",
      "id": 5,
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Value", "desc": true }],
        "cellHeight": "sm",
        "footer": {
          "show": true,
          "reducer": ["sum", "mean", "count"],
          "countRows": false
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "$query",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": []
    }
  ],
  "refresh": "",
  "schemaVersion": 39,
  "tags": ["explorer", "adhoc"],
  "uid": "adhoc-explorer",
  "version": 0
}
