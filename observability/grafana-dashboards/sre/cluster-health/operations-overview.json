{
  "description": "Fleet-wide view of all provisioning operations — current state, stuck operations (>20min), failed operations with error details, and operation rates over time. Uses the global fleet-metrics AMW.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": true,
      "title": "Resource State",
      "tooltip": "Fleet resource state overview (ARO-25164)",
      "type": "link",
      "url": "/d/resource-state/resource-state"
    }
  ],
  "panels": [
    {
      "datasource": {
        "default": false,
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 80
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "succeeded" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "provisioning" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "deleting" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "accepted" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "awaitingsecret" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "barRadius": 0.1,
        "barWidth": 0.8,
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true },
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none",
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "count by (phase) (backend_resource_operation_phase_info{resource_type=\"microsoft.redhatopenshift/hcpopenshiftclusters\", subscription_id!~\"$exclude_subs\"} == 1)",
          "instant": true,
          "legendFormat": "{{phase}}",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Cluster Operations by Phase",
      "type": "barchart"
    },
    {
      "datasource": {
        "default": false,
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "create" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "delete" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "update" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "barRadius": 0.1,
        "barWidth": 0.8,
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true },
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none",
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "count by (operation_type) (backend_resource_operation_phase_info{resource_type=\"microsoft.redhatopenshift/hcpopenshiftclusters\", subscription_id!~\"$exclude_subs\"} == 1)",
          "instant": true,
          "legendFormat": "{{operation_type}}",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Operations by Type (Create/Delete/Update)",
      "type": "barchart"
    },
    {
      "datasource": {
        "default": false,
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1200 },
              { "color": "red", "value": 3600 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": true, "fields": "", "reducer": ["count"], "show": true },
        "showHeader": true,
        "sortBy": [
          { "desc": true, "displayName": "Duration" }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "(time() - backend_resource_operation_last_transition_time_seconds{resource_type=\"microsoft.redhatopenshift/hcpopenshiftclusters\", phase=~\"provisioning|accepted|awaitingsecret|updating|deleting\", subscription_id!~\"$exclude_subs\"}) > 1200",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Stuck Operations (In-Flight > 20 min)",
      "type": "table"
    },
    {
      "datasource": {
        "default": false,
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        }
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "id": 4,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": true, "fields": "", "reducer": ["count"], "show": true },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "backend_resource_operation_phase_info{resource_type=\"microsoft.redhatopenshift/hcpopenshiftclusters\", phase=\"failed\", subscription_id!~\"$exclude_subs\"} == 1",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Failed Operations",
      "type": "table"
    },
    {
      "datasource": {
        "default": false,
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 20,
            "gradientMode": "hue",
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "succeeded" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "count by (phase) (backend_resource_operation_phase_info{resource_type=\"microsoft.redhatopenshift/hcpopenshiftclusters\", subscription_id!~\"$exclude_subs\"} == 1)",
          "instant": false,
          "legendFormat": "{{phase}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Operations by Phase Over Time",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": ["aro-hcp", "sre", "fleet"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "^Managed_Prometheus_fleet-.*$",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "description": "Pipe-separated subscription IDs to exclude from calculations",
        "hide": 0,
        "label": "Exclude Subscriptions",
        "name": "exclude_subs",
        "options": [
          { "selected": true, "text": "", "value": "" }
        ],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "utc",
  "title": "Operations Overview",
  "uid": "operations-overview",
  "version": 1,
  "weekStart": ""
}
