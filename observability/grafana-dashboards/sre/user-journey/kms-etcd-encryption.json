      "targets": [
        {
          "expr": "apiserver_envelope_encryption_dek_source_cache_size{namespace=~\"$hcp\"}",
          "legendFormat": "{{ namespace }} ({{ instance }})"
        }
      ],
      "title": "DEK Cache Size per KAS Pod",
      "type": "timeseries",
      "pluginVersion": "11.6.9",
      "options": {
        "legend": {
