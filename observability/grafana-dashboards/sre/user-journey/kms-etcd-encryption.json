        "w": 12,
        "x": 0,
        "y": 18
      },
      "id": 8,
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (namespace, cluster, le) (apiserver_envelope_encryption_kms_operations_latency_seconds_bucket{namespace=~\"$hcp\", method_name=\"/v2.keymanagementservice/encrypt\", grpc_status_code=\"0\"}))",
          "legendFormat": "encrypt p99 {{ namespace }}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (namespace, cluster, le) (apiserver_envelope_encryption_kms_operations_latency_seconds_bucket{namespace=~\"$hcp\", method_name=\"/v2.keymanagementservice/decrypt\", grpc_status_code=\"0\"}))",
          "legendFormat": "decrypt p99 {{ namespace }}"
        },
        {
          "expr": "vector(0.5)",
          "legendFormat": "SLO Target (500ms)"
        }
