    {
      "datasource": {
        "type": "datasource",
        "uid": "-- Mixed --"
      },
      "description": "SLI: share of in-flight upgrades not contributing to stuck rate (1 − stuck/in-flight).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 3,
          "mappings": [],
          "max": 100,
          "min": 99.9,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red"
              },
              {
                "color": "yellow",
                "value": 99.95
              },
              {
                "color": "green",
                "value": 99.99
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 6
      },
      "id": 3,
