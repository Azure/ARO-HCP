        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "11.6.9",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
          },
          "editorMode": "code",
          "expr": "(1 - (hosted_control_plane_upgrade:desired:stuck_over_20m:ratio{cluster=~\"$cluster\"} or vector(0))) * 100",
          "instant": true,
          "legendFormat": "SLI %",
          "refId": "A"
        }
      ],
      "title": "Cluster Upgrade Version Reach Partial SLI",
      "type": "stat"
