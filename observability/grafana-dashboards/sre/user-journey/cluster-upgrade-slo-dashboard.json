          "editorMode": "code",
          "expr": "(\n  (\n    min without(state) (hosted_control_plane_upgrade:version_state_first_seen:timestamp{cluster=~\"$cluster\", state=\"partial\"})\n    - on(cluster, resource_id, subscription_id, cluster_uuid, version) group_left()\n    hosted_control_plane_upgrade:version_state_first_seen:timestamp{cluster=~\"$cluster\", state=\"desired\"}\n  )\n  and on(cluster, resource_id, subscription_id, cluster_uuid, version) (\n    max without(state) (backend_cluster_version_info{cluster=~\"$cluster\", state=\"partial\"}) == 1\n  )\n) / 60",
          "legendFormat": "{{ resource_id }} {{ version }}",
          "refId": "A"
        }
