          "expr": "sum by (container) (increase(kube_pod_container_status_terminated_reason{cluster=\"$cluster\", namespace=\"$namespace\", reason=\"OOMKilled\"}[5m]))",
          "legendFormat": "{{container}}",
          "refId": "A"
