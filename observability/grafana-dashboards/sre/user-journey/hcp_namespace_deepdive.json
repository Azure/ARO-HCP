      ],
      "title": "Last Terminated Reason per Container",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "cluster": true,
              "job": true,
              "namespace": true
            },
            "indexByName": {},
            "renameByName": {
              "Value": "Active",
              "container": "Container",
              "pod": "Pod",
              "reason": "Termination Reason"
            }
          }
        },
        {
          "id": "filterByValue",
          "options": {
            "filters": [
              {
                "config": {
                  "id": "greater",
                  "options": {
                    "value": 0
                  }
                },
                "fieldName": "Active"
              }
            ],
            "match": "any",
            "type": "include"
          }
        }
      ],
      "type": "table"
