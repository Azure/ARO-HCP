    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "description": "Top 10 pods with the most container restarts in the last hour. Use this to identify specific problematic pods.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
