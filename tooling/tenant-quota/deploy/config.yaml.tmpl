# Templatize template that renders the tool's config directly from
# config-dev-ci.yaml. Used for local development (make run, make setup-sp).
#
# This produces the same config shape as deploy/templates/configmap.yaml
# but skips the Helm rendering step.
#
# Usage:
#   templatize generate \
#     --config-file config/config-dev-ci.yaml \
#     --dev-settings-file tooling/templatize/settings.yaml \
#     --dev-environment dev-ci \
#     --input deploy/config.yaml.tmpl \
#     --output _output/config.yaml
#
interval: "5m"
timeout: "30s"
cacheTTL: "24h"
tenants:
{{- range .opstool.tenantQuota.tenants }}
- tenantId: "{{ .tenantId }}"
  tenantName: "{{ .tenantName }}"
  servicePrincipalClientId: "{{ .servicePrincipalClientId }}"
  keyVaultSecretName: "{{ .keyVaultSecretName }}"
  scope: "https://graph.microsoft.com/.default"
  directoryQuota: {{ .directoryQuota }}
  subscriptions:
{{- range .subscriptions }}
  - name: "{{ .name }}"
    roleAssignmentLimit: {{ .roleAssignmentLimit }}
    regions:
{{- range .regions }}
    - "{{ . }}"
{{- end }}
{{- end }}
{{- end }}
