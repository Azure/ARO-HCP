{{ template "bundleMap" . }}
cluster('{{ .ClusterURI }}').database('{{ .ServiceDatabase }}').table('containerLogs')
| where timestamp between ({{ kqlDatetime .StartTime }} .. {{ kqlDatetime .EndTime }})
| where namespace_name == 'maestro'
| where container_name == 'maestro-agent'
| extend logs = tostring(log)
| extend bundleId = extract('"resourceid":"([^"]+)"', 1, logs)
| extend logResourceName = extract('resourceName="([^"]+)"', 1, logs)
| lookup resourceNameToBundleId on $left.logResourceName == $right.resourceName
| extend bundleId = coalesce(bundleId, bundleId1)
| where isnotempty(bundleId)
| where bundleId in (bundleIds)
| extend logResourceNamespace = extract('resourceNamespace="([^"]+)"', 1, logs)
| extend message = extract('] "([^"]+)"', 1, logs)
| lookup bundleMap on bundleId
| project timestamp, groupVersion, resourceKind, label, bundleId, logResourceNamespace, logResourceName, message
| order by timestamp asc
