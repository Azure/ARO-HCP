        "replacementType": "Consistent",
        "target": "All",
        "type": "Regex"
      },
      {
        "regex": "(kubernetes\\.azure\\.com/podnetwork-delegationguid[\"':\\s=]+)([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12})",
        "replacementType": "Consistent",
        "target": "All",
        "type": "Regex"
      },
      {
        "regex": "(kubernetes\\.azure\\.com/kubelet-identity-client-id[\"':\\s=]+)([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12})",
