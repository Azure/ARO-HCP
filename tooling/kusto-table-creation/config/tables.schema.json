{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "definitions": {
      "type": "array",
      "items": { "$ref": "#/$defs/definition" }
    },
    "tables": {
      "type": "array",
      "items": { "$ref": "#/$defs/table" }
    }
  },
  "$defs": {
    "column": {
      "type": "object",
      "required": ["name", "type", "mapping"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["bool", "datetime", "dynamic", "guid", "int", "long", "real", "string", "timespan", "decimal"]
        },
        "mapping": { "type": "string", "minLength": 1 }
      }
    },
    "definition": {
      "type": "object",
      "required": ["name", "columns"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "columns": {
          "type": "array",
          "items": { "$ref": "#/$defs/column" }
        }
      }
    },
    "table": {
      "type": "object",
      "required": ["name", "databases"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "databases": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "definitions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "columns": {
          "type": "array",
          "items": { "$ref": "#/$defs/column" }
        }
      }
    }
  }
}
